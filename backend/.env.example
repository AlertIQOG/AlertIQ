# ─── Environment Variables ────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# App Settings
APP_NAME="AlertIQ Backend"
APP_VERSION="0.1.0"
DEBUG=False

# Server
HOST=0.0.0.0
PORT=8000

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3000"]

# ─── Settings ────────────────────────────────────────────────────
# Database Setup
DATABASE_URL="postgresql://user:password@localhost:5432/alertiq"

# ─── Notifications ────────────────────────────────────────────────
# Slack — create an Incoming Webhook (Slack app → Incoming Webhooks → Add to a channel)
SLACK_WEBHOOK_URL=""

# Email (SMTP). For Gmail: host=smtp.gmail.com, port=587, TLS on, and SMTP_PASSWORD is an
# App Password (Google account must have 2FA enabled to create one).
SMTP_HOST=""
SMTP_PORT=587
SMTP_USERNAME=""
SMTP_PASSWORD=""
SMTP_FROM=""              # defaults to SMTP_USERNAME when empty
SMTP_USE_TLS=True
EMAIL_DEFAULT_TO=""       # fallback recipient for the /notifications/test endpoint

# ─── Future Settings (uncomment when needed) ──────────────────────────────────
# SECRET_KEY=your-secret-key-here
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
