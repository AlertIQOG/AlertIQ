# ─── Environment Variables ────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# App Settings
APP_NAME="AlertIQ Backend"
APP_VERSION="0.1.0"
DEBUG=False

# Server
HOST=0.0.0.0
PORT=8000

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3000"]

# ─── Settings ────────────────────────────────────────────────────
# Database Setup
DATABASE_URL="postgresql://user:password@localhost:5432/alertiq"

# ─── Notifications ────────────────────────────────────────────────
# Slack — create an Incoming Webhook (Slack app → Incoming Webhooks → Add to a channel)
SLACK_WEBHOOK_URL=""

# Email (SMTP). For Gmail: host=smtp.gmail.com, port=587, TLS on, and SMTP_PASSWORD is an
# App Password (Google account must have 2FA enabled to create one).
SMTP_HOST=""
SMTP_PORT=587
SMTP_USERNAME=""
SMTP_PASSWORD=""
SMTP_FROM=""              # defaults to SMTP_USERNAME when empty
SMTP_USE_TLS=True
EMAIL_DEFAULT_TO=""       # fallback recipient for the /notifications/send endpoint

# ─── Resolution Copilot (RAG) ─────────────────────────────────────
# Generation provider: "anthropic" or "google".
#   - anthropic → set ANTHROPIC_API_KEY
#   - google    → set GOOGLE_API_KEY
# Embeddings always use Voyage, so VOYAGE_API_KEY is required either way.
LLM_PROVIDER=anthropic

# Anthropic Claude (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# Google Gemini (used when LLM_PROVIDER=google)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Embeddings — provider: "voyage" or "google"
#   - google → reuses GOOGLE_API_KEY (no extra key); set EMBEDDING_DIM=768
#   - voyage → set VOYAGE_API_KEY; set EMBEDDING_DIM=1024
# NOTE: changing the provider/model/dim requires re-embedding the corpus
# (drop rag_chunks, then re-run `python -m app.scripts.backfill_rag`).
EMBEDDING_PROVIDER=google
GOOGLE_EMBEDDING_MODEL=gemini-embedding-001
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIM=768

# Retrieval tuning
RAG_TOP_K=5
RAG_RELEVANCE_FLOOR=0.5

# ─── Future Settings (uncomment when needed) ──────────────────────────────────
# SECRET_KEY=your-secret-key-here
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
